# Server Port
PORT=3001

# Groq API Key (Used for Whisper audio transcription)
GROQ_API_KEY=your_groq_api_key

# Gemini API Key (Used for Instagram carousel OCR text extraction)
GEMINI_API_KEY=your_gemini_api_key

# Apify API Token (Used for TikTok and Instagram metadata scraping)
APIFY_TOKEN=your_apify_api_token
